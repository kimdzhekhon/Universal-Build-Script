# Copy this file to .env.macos and fill in your signing identities.
# List available identities: security find-identity -v -p codesigning

# App signing identity (Apple Distribution certificate)
TAURI_SIGN_IDENTITY="Apple Distribution: Your Name (TEAMID)"

# Installer package signing identity (3rd Party Mac Developer Installer certificate)
TAURI_INSTALLER_IDENTITY="3rd Party Mac Developer Installer: Your Name (TEAMID)"

# Optional overrides — by default the script auto-detects the first
# *.provisionprofile / *.entitlements file under signing/
# TAURI_PROVISION_PROFILE=signing/App.provisionprofile
# TAURI_ENTITLEMENTS=signing/app.entitlements
