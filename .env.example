# Flutter 앱 환경변수 템플릿
# 이 파일을 복사하여 .env로 저장 후 실제 값을 입력하세요.
# .env 파일은 .gitignore에 추가하여 커밋하지 마세요.
#
# 사용법:
#   개발: flutter run --dart-define-from-file=.env
#   배포: bash build.sh  (스크립트가 자동으로 주입)

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>

# Google OAuth
GOOGLE_IOS_CLIENT_ID=<project-number>-<hash>.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=<project-number>-<hash>.apps.googleusercontent.com
